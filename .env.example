# Copy to .env and adjust. All backend vars are prefixed NEXUS_.

# --- core ---
NEXUS_ENV=development
NEXUS_JWT_SECRET=replace-with-a-long-random-secret

# --- datastores ---
NEXUS_DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus
NEXUS_REDIS_URL=redis://localhost:6379/0

# --- auth ---
NEXUS_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# --- model layer (leave provider=demo to run fully offline) ---
NEXUS_LLM_PROVIDER=demo
NEXUS_LLM_MODEL=gpt-5.5
NEXUS_OPENAI_API_KEY=
NEXUS_WHISPER_MODEL=whisper-1
NEXUS_YOLO_WEIGHTS=
NEXUS_SAM_CHECKPOINT=

# --- frontend (Next.js public vars) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token
